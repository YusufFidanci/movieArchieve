@model IEnumerable<movieArchieve.Entities.MovieLangs>

@{
    ViewData["Title"] = "Add Movie Language";
}

<h1>Add Movie Language</h1>

<form method="post" action="/MovieLangs/Create">
    
    <div>
        <label>Language Name</label>
        <input type="text" name="langName" required />
    </div>
    
    <button type="submit">Add Language</button>

</form>