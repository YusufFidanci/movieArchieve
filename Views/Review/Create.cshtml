@model IEnumerable<movieArchieve.Entities.Review>

@{
    ViewData["Title"] = "Add Review";
}

<h1>Add Review</h1>

<form method="post" action="/Review/Create">
    
    <div>
        <label>Language Name</label>
        <input type="text" name="langName" required />
    </div>
    
    <div>
        <label>CreatedAt</label>
        <input type="datetime-local" name="createdAt"/>
    </div>

    <button type="submit">Add Review</button>

</form>

<a href="/Review">Back to Review List</a>