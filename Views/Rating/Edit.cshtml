@model movieArchieve.Entities.Rating

@{
    ViewData["Title"] = "Edit Movie Language";
}

<h1>Edit Movie Language</h1>

<form method="post" action="/Rating/Edit">
    <input type="hidden" name="ratingID" value="@Model.ratingID" />

    <div>
        <label>Score</label>
        <input type="number" step="0.1" name="score" value="@Model.score" required />
    </div>
    
    <button type="submit">Update Rating</button>

</form>

<a href="/Rating/Index">Back to Rating List</a>