@model IEnumerable<movieArchieve.Entities.Rating>

@{
    ViewData["Title"] = "Rating List";
}

<h1>Rating List</h1>

<a href="/Rating/Create">Add New Rating</a>

<table>
    <div>
        <label>Score</label>
        <input type ="number" step="0.1" name="score" required>
    </div>

    <div>
        <label>CreatedAt</label>
        <input type="datetime-local" name="createdAt" required>
    </div>

    <button type="submit">Add Rating</button>

</table>

<a href="/Rating/Index">Back to Rating List</a> 