@model IEnumerable<movieArchieve.Entities.Ratings>

@{
    ViewData["Title"] = "Ratings List";
}

<h1>Ratings List</h1>

<a href="/Ratings/Create">Add New Rating</a>

<table>
    <div>
        <label>Score</label>
        <input type ="number" step="0.1" name="scor" required>
    </div>

    <div>
        <label>CreatedAt</label>
        <input type="datetime-local" name="createdAt" required>
    </div>

    <button type="submit">Add Rating</button>

</table>
